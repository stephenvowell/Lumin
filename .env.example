GROQ_API_KEY=

# Personality: casual_friend | calm_butler | witty_co_pilot
LUMIN_PERSONALITY=witty_co_pilot
LUMIN_USER_NAME=Stephen
# Optional: override the personality prompt entirely (memory + time context still apply)
# LUMIN_SYSTEM_PROMPT=

# Voice (leave blank to use personality defaults)
TTS_VOICE=
TTS_RATE=
TTS_PITCH=
STT_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.3-70b-versatile
# TEMPERATURE=0.85
MAX_TOKENS=1000
MAX_HISTORY_MESSAGES=20

# Memory across sessions (saved to data/user_profile.json)
MEMORY_ENABLED=true
MEMORY_FILE=data/user_profile.json

# Microphone (run: python lumin.py --list-mics)
MIC_INDEX=
LISTEN_TIMEOUT=10
PHRASE_TIME_LIMIT=15
LISTEN_CHIME=true

# Logs
LOG_DIR=logs
TIMEZONE=America/Chicago

# Internet search (DuckDuckGo - no extra API key needed)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_FETCH_MAX_CHARS=4000
WEB_FETCH_TIMEOUT=12
